# Retell AI — https://dashboard.retellai.com  (Settings → API Keys)
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxx

# Anthropic — used to compile the user's raw prompt into a structured Retell prompt.
# Optional: if unset, the raw prompt is passed through to Retell unchanged.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Public base URL used to build the shareable agent link.
# Local dev: http://localhost:3000   Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
